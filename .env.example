# NSE Indices Fetcher Configuration

# Flask Configuration
FLASK_ENV=development
DEBUG=true
PORT=5000

# API Configuration
CACHE_DURATION=60
REFRESH_INTERVAL=60000

# Redis Configuration (optional, for production caching)
REDIS_URL=redis://localhost:6379/0

# API Keys (if needed for premium data sources)
# INDIAN_API_KEY=your_api_key_here
# YAHOO_FINANCE_API_KEY=your_api_key_here

# Logging Configuration
LOG_LEVEL=INFO